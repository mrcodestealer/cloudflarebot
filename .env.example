# ============================================================
#  cloudflarebot  —  copy to .env and fill in your values
# ============================================================

# ---- Cloudflare data source ----
CF_MODE=api                      # "api" (recommended) or "browser"
CF_API_TOKEN=                    # token with Zone > Analytics > Read (+ Zone:Read to auto-resolve id)
CF_ZONE_TAG=                     # zone id (optional if token has Zone:Read)

# ---- Cloudflare dashboard login (only used when CF_MODE=browser) ----
CF_EMAIL=you@example.com
CF_PASSWORD='your-password'
CF_ACCOUNT_ID=your_account_id
CF_ZONE=example.com
CF_ANALYTICS_URL=https://dash.cloudflare.com/<account_id>/<zone>/security/analytics?mitigation-service=l7ddos&time-window=360
CF_HEADLESS=true
# Optional: path to a system Chromium if the bundled build won't run (e.g. old glibc)
CF_CHROMIUM_PATH=

# ---- Lark / Feishu app ----
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_ENCRYPT_KEY=
# Lark (global): https://open.larksuite.com   |   Feishu (China): https://open.feishu.cn
LARK_DOMAIN=https://open.larksuite.com
LARK_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: bot's open_id (ou_...) for precise @-mention detection; leave blank to accept any mention
LARK_BOT_OPEN_ID=
LARK_REACTION_PROCESSING=OK
LARK_REACTION_DONE=DONE
# Optional: Lark user open_ids (ou_...) to @-mention on a spike alert, so a human
# is pinged to look. Rendered as real @mentions in the card. Space/comma-separated;
# empty = mention nobody. PM the bot "/whoami" to get an open_id.
ALERT_MENTION_OPEN_IDS=
# Short note shown after the @mentions on the alert card.
ALERT_MENTION_NOTE=kindly check

# ---- Remote deploy (/deploy command) ----
# Space/comma-separated Lark user open_ids (ou_...) allowed to trigger a
# git pull + service restart by messaging the bot in a 1:1 PM. Empty = disabled.
# PM the bot "/whoami" to get your own open_id.
ADMIN_OPEN_IDS=
# Service name (used by the default restart command below).
DEPLOY_SERVICE=cloudflarebot.service
# How to restart. Default (blank) = "systemd-run --no-block systemctl restart <DEPLOY_SERVICE>",
# which runs the restart in its own transient unit so it survives the bot being
# killed by the restart. The service runs as root, so no sudo is needed; if you
# run it as a non-root user, set e.g. DEPLOY_RESTART_CMD='sudo systemd-run --no-block systemctl restart cloudflarebot.service'
DEPLOY_RESTART_CMD=

# ---- Qwen via Ollama ----
OLLAMA_HOST=http://localhost:11434
QWEN_MODEL=qwen3.6:35b-a3b
QWEN_TIMEOUT=300

# ---- Spike detection ----
SPIKE_STD_MULTIPLIER=4.0
SPIKE_BASELINE_WINDOW=20
SPIKE_MIN_FLOOR=10000        # ignore mitigation blips below this many requests / 5-min bucket
SPIKE_WARMUP=6
SPIKE_PRIME_GRACE_MIN=20     # on restart, still alert spikes from the last N minutes

# ---- Monitor loop ----
POLL_INTERVAL_SECONDS=30
STATE_DIR=state

# ---- Display timezone (Cloudflare data is UTC; shown in this offset) ----
DISPLAY_TZ_OFFSET=8
DISPLAY_TZ_LABEL=GMT+8
